{
  "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace",
  "editor.tabSize": 2,
  "editor.lineHeight": 25,
  "editor.fontLigatures": true,
  "window.zoomLevel": 0,
  "editor.letterSpacing": 0.5,
  "editor.fontSize": 11,
  "editor.multiCursorModifier": "ctrlCmd",
  "typescript.check.npmIsInstalled": false,
  "workbench.colorCustomizations": {
    "activityBarBadge.background": "#80CBC4",
    "list.activeSelectionForeground": "#80CBC4",
    "list.inactiveSelectionForeground": "#80CBC4",
    "list.highlightForeground": "#80CBC4",
    "scrollbarSlider.activeBackground": "#80CBC450",
    "editorSuggestWidget.highlightForeground": "#80CBC4",
    "textLink.foreground": "#80CBC4",
    "progressBar.background": "#80CBC4",
    "pickerGroup.foreground": "#80CBC4",
    "tab.activeBorder": "#80CBC4",
    "notificationLink.foreground": "#80CBC4",
    "editorIndentGuide.activeBackground": "#808080"
  },
  "workbench.activityBar.visible": true,
  "terminal.integrated.shell.osx": "/bin/zsh",
  "workbench.sideBar.location": "left",
  "files.insertFinalNewline": true,
  "editor.autoIndent": true,
  "search.exclude": {
    "**/*.map": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/build": true,
    "**/public": true
  },
  "files.exclude": {
    "**/node_modules/": true
  },
  "window.restoreFullscreen": true,
  "window.newWindowDimensions": "maximized",
  "markdown.preview.breaks": true,
  "git.enableSmartCommit": true,
  "javascript.validate.enable": false,
  "workbench.startupEditor": "none",
  "files.trimTrailingWhitespace": true,
  "workbench.iconTheme": "vscode-icons",
  "workbench.colorTheme": "Night Owl",
  "editor.snippetSuggestions": "top",
  "vsicons.dontShowNewVersionMessage": true,
  "editor.formatOnSave": true,
  "prettier.printWidth": 140,
  "prettier.singleQuote": true,
  "prettier.useTabs": false,
  "files.autoSave": "off",
  "emmet.syntaxProfiles": {
    "javascript": "jsx"
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact"
  },
  "files.associations": {
    "*.js": "javascriptreact"
  },
  "editor.formatOnPaste": true,
  "editor.formatOnType": false,
  "editor.matchBrackets": false,
  "explorer.decorations.badges": false,
  "editor.fontWeight": "400",
  "prettier.eslintIntegration": true,
  "editor.cursorWidth": 2,
  "editor.renderWhitespace": "all",
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": true,
  "gitlens.advanced.messages": {
    "suppressShowKeyBindingsNotice": true
  },
  "gitlens.gitExplorer.files.layout": "list",
  "gitlens.explorers.avatars": false,
  "gitlens.gitExplorer.autoRefresh": false,
  "gitlens.currentLine.enabled": false,
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.blame.heatmap.enabled": false,
  "gitlens.blame.avatars": false,
  "gitlens.blame.compact": false,
  "gitlens.blame.highlight.enabled": false,
  "gitlens.hovers.enabled": false,
  "gitlens.historyExplorer.enabled": true,
  "gitlens.views.repositories.autoRefresh": false,
  "gitlens.views.repositories.files.layout": "list",
  "gitlens.views.fileHistory.enabled": true,
  "gitlens.views.lineHistory.enabled": true,
  "gitlens.views.avatars": false,
  "gitlens.views.compare.avatars": false,
  "gitlens.views.repositories.avatars": false,
  "gitlens.views.search.avatars": false,
}
